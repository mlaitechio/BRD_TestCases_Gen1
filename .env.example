AI_PROVIDER=claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
DJANGO_SECRET_KEY=your-django-secret-key-here
# DEBUG=True  # Uncomment to override automatic APP_ENV behavior (True in dev, False in prod)
REDIS_URL=redis://127.0.0.1:6379/0

# ── URL Prefix ────────────────────────────────────────────────────────────────
# Temporarily serving project under /chatgpt prefix. Set to empty string (URL_PREFIX=) to move back to root (/).
URL_PREFIX=chatgpt/

# ── App Environment (prod / dev) ──────────────────────────────────────────────
# Change APP_ENV between "prod" and "dev" to automatically configure DEBUG, ALLOWED_HOSTS, CORS, CSRF, and SSL settings.
APP_ENV=dev

# ── CyberArk OAuth2 / OIDC ────────────────────────────────────────────────────
# Obtain these from your CyberArk Identity tenant (or PAM OIDC app registration)
CLIENT_ID=your-cyberark-client-id
CLIENT_SECRET=your-cyberark-client-secret

# CyberArk Identity example:
#   AUTH_URL      = https://<tenant>.cyberark.cloud/oauth2/authorize/<app-id>
#   TOKEN_URL     = https://<tenant>.cyberark.cloud/oauth2/token/<app-id>
#   USER_INFO_URL = https://<tenant>.cyberark.cloud/oauth2/userinfo/<app-id>
AUTH_URL=https://<tenant>/oauth2/authorize
TOKEN_URL=https://<tenant>/oauth2/token
USER_INFO_URL=https://<tenant>/oauth2/userinfo

# The URL Django will use as the OAuth2 redirect_uri.
# Must match exactly what is registered in CyberArk.
# In dev this defaults to http://localhost:8000 automatically.
PROD_URL=https://your-app.example.com

# ── JWT Settings ───────────────────────────────────────────────────────────────
# JWT_SECRET        — primary HS256 signing secret (use a long random string)
# JWT_SECRETS       — comma-separated list of additional/rotation secrets
JWT_SECRET=your-jwt-signing-secret-here
JWT_SECRETS=
JWT_ALGORITHM=HS256
JWT_ISSUER=brd-verification-backend
JWT_AUDIENCE=brd-verification-app

# ── Production Proxy ───────────────────────────────────────────────────────────
# Only used when APP_ENV=prod; leave blank in dev
HTTP_PROXY=
HTTPS_PROXY=

# ── CORS (comma-separated, used in production) ────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
