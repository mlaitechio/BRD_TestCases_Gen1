              "raw": "{{base_url}}/api/projects/{{project_id}}/download/effort/",
              "host": ["{{base_url}}"],
              "path": ["api", "projects", "{{project_id}}", "download", "effort", ""]
            },
            "description": "Downloads the Effort Estimation Report as a formatted Word document.\n\nIncludes hours breakdown by phase/role/feature and 3-point cost estimate."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is DOCX', () => {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('vnd.openxmlformats');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "06 — Error Case Tests",
      "description": "Tests for edge cases and error conditions.",
      "item": [
        {
          "name": "06.1 Create Project Without Input (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
